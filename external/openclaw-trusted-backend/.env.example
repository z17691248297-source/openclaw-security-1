# Network
TRUSTED_BACKEND_HOST=127.0.0.1
TRUSTED_BACKEND_PORT=19090

# Token signing
TRUSTED_VERIFY_MODE=hmac-sha256
TRUSTED_HMAC_KEY=replace-with-a-long-random-shared-secret
# TRUSTED_SIGNING_PRIVATE_KEY_FILE=/path/to/ed25519-private.pem

# Backend behavior
TRUSTED_BACKEND_ADAPTOR=local-tdx
TRUSTED_POLICY_PATH=./policy.json
TRUSTED_BACKEND_EVENTS_FILE=./logs/trusted-backend-events.jsonl

# Optional TDX guest identity / attestation inputs
# TRUSTED_TDX_GUEST_ID=tdx-guest:vm-01
# TRUSTED_TDX_SERVICE_NAME=openclaw-trusted-backend
# TRUSTED_TDX_MEASUREMENT=<hex measurement>
# TRUSTED_TDX_QUOTE_FORMAT=tdx-quote-v4
# TRUSTED_TDX_QUOTE_BASE64=<base64 quote>
# TRUSTED_TDX_ATTESTATION_FILE=./tdx-attestation.json
# TRUSTED_TDX_ATTESTATION_COMMAND=/usr/local/bin/openclaw-tdx-attest
# TRUSTED_TDX_ATTESTATION_COMMAND_TIMEOUT_MS=2000
