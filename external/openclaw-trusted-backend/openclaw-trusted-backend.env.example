TRUSTED_BACKEND_HOST=0.0.0.0
TRUSTED_BACKEND_PORT=19090
TRUSTED_BACKEND_ADAPTOR=local-tdx
TRUSTED_POLICY_PATH=/opt/openclaw-trusted-backend/policy.json
TRUSTED_BACKEND_EVENTS_FILE=/var/lib/openclaw-trusted-backend/trusted-backend-events.jsonl

# Preferred production mode
TRUSTED_VERIFY_MODE=ed25519
TRUSTED_SIGNING_PRIVATE_KEY_FILE=/etc/openclaw-trusted-backend/ed25519-private.pem

# Optional TDX guest identity / attestation plumbing
# TRUSTED_TDX_GUEST_ID=tdx-guest:prod-01
# TRUSTED_TDX_SERVICE_NAME=openclaw-trusted-backend
# TRUSTED_TDX_MEASUREMENT=<hex measurement>
# TRUSTED_TDX_QUOTE_FORMAT=tdx-quote-v4
# TRUSTED_TDX_ATTESTATION_FILE=/etc/openclaw-trusted-backend/tdx-attestation.json
# TRUSTED_TDX_ATTESTATION_COMMAND=/usr/local/bin/openclaw-tdx-attest
# TRUSTED_TDX_ATTESTATION_COMMAND_TIMEOUT_MS=2000

# HMAC fallback for development only
# TRUSTED_VERIFY_MODE=hmac-sha256
# TRUSTED_HMAC_KEY=replace-with-shared-secret
